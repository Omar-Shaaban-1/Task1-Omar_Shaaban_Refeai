<?xml version="1.0"?>
<robot name="robotic_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       Robotic-Arm: 6-DOF manipulator description
       Matches the DH parameters used in fk_solver.py so simulated
       results and math results agree.
       ============================================================ -->

  <xacro:property name="link_mass" value="1.0" />
  <xacro:property name="joint_damping" value="0.1" />
  <xacro:property name="joint_friction" value="0.0" />
  <xacro:property name="effort_limit" value="150.0" />
  <xacro:property name="velocity_limit" value="3.0" />

  <material name="arm_grey">
    <color rgba="0.6 0.6 0.65 1.0" />
  </material>
  <material name="joint_orange">
    <color rgba="0.9 0.5 0.1 1.0" />
  </material>

  <xacro:macro name="inertial_box" params="mass x y z">
    <inertial>
      <mass value="${mass}" />
      <inertia
        ixx="${mass*(y*y+z*z)/12.0}" ixy="0.0" ixz="0.0"
        iyy="${mass*(x*x+z*z)/12.0}" iyz="0.0"
        izz="${mass*(x*x+y*y)/12.0}" />
    </inertial>
  </xacro:macro>

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
      <material name="arm_grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.08" length="0.05"/></geometry>
    </collision>
    <xacro:inertial_box mass="2.0" x="0.16" y="0.16" z="0.05"/>
  </link>

  <!-- ================= JOINT 1 -> LINK 1 (shoulder yaw) ================= -->
  <link name="link_1">
    <visual><origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.30"/></geometry>
      <material name="arm_grey"/></visual>
    <collision><origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.30"/></geometry></collision>
    <xacro:inertial_box mass="${link_mass}" x="0.1" y="0.1" z="0.30"/>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/><child link="link_1"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="${effort_limit}" velocity="${velocity_limit}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <!-- ================= JOINT 2 -> LINK 2 (shoulder pitch) ================= -->
  <link name="link_2">
    <visual><origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.30"/></geometry>
      <material name="joint_orange"/></visual>
    <collision><origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.30"/></geometry></collision>
    <xacro:inertial_box mass="${link_mass}" x="0.09" y="0.09" z="0.30"/>
  </link>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/><child link="link_2"/>
    <origin xyz="0 0 0.30" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="${effort_limit}" velocity="${velocity_limit}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <!-- ================= JOINT 3 -> LINK 3 (elbow) ================= -->
  <link name="link_3">
    <visual><origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.30"/></geometry>
      <material name="arm_grey"/></visual>
    <collision><origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.30"/></geometry></collision>
    <xacro:inertial_box mass="${link_mass}" x="0.08" y="0.08" z="0.30"/>
  </link>
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/><child link="link_3"/>
    <origin xyz="0 0 0.30" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.5" upper="2.5" effort="${effort_limit}" velocity="${velocity_limit}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <!-- ================= JOINT 4 -> LINK 4 (wrist roll) ================= -->
  <link name="link_4">
    <visual><origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.20"/></geometry>
      <material name="joint_orange"/></visual>
    <collision><origin xyz="0 0 0.10" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.20"/></geometry></collision>
    <xacro:inertial_box mass="${link_mass}" x="0.07" y="0.07" z="0.20"/>
  </link>
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/><child link="link_4"/>
    <origin xyz="0 0 0.30" rpy="0 1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="${effort_limit}" velocity="${velocity_limit}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <!-- ================= JOINT 5 -> LINK 5 (wrist pitch) ================= -->
  <link name="link_5">
    <visual><origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.16"/></geometry>
      <material name="arm_grey"/></visual>
    <collision><origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.03" length="0.16"/></geometry></collision>
    <xacro:inertial_box mass="0.5" x="0.06" y="0.06" z="0.16"/>
  </link>
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/><child link="link_5"/>
    <origin xyz="0 0 0.20" rpy="0 -1.5708 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="${effort_limit}" velocity="${velocity_limit}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <!-- ================= JOINT 6 -> END EFFECTOR (wrist yaw / gripper mount) ================= -->
  <link name="end_effector">
    <visual><geometry><box size="0.04 0.04 0.06"/></geometry>
      <material name="joint_orange"/></visual>
    <collision><geometry><box size="0.04 0.04 0.06"/></geometry></collision>
    <xacro:inertial_box mass="0.3" x="0.04" y="0.04" z="0.06"/>
  </link>
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/><child link="end_effector"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="${effort_limit}" velocity="${velocity_limit}"/>
    <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
  </joint>

  <!-- ================= TRANSMISSIONS (bridge URDF -> Gazebo motors) ================= -->
  <xacro:macro name="transmission_block" params="joint_name">
    <transmission name="${joint_name}_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${joint_name}">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${joint_name}_motor">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
  </xacro:macro>

  <xacro:transmission_block joint_name="joint_1"/>
  <xacro:transmission_block joint_name="joint_2"/>
  <xacro:transmission_block joint_name="joint_3"/>
  <xacro:transmission_block joint_name="joint_4"/>
  <xacro:transmission_block joint_name="joint_5"/>
  <xacro:transmission_block joint_name="joint_6"/>

  <!-- Gazebo ros2_control plugin: connects controllers to simulated motors -->
  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find robotic_arm)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
